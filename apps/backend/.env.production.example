# Production environment template — Render (or any Node host).
# Copy these into your host's environment-variable dashboard. Do NOT commit a
# real .env.production file with real secrets.

NODE_ENV=production
PORT=4000

# --- Database: Neon (https://neon.tech) ---
# Create a project, copy the "pooled connection" string. Must end with
# ?sslmode=require. Neon supports the citext/vector/pgcrypto extensions this
# app's first migration creates automatically.
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require

# --- Redis: Upstash (https://upstash.com) ---
# Create a Redis database, copy the "rediss://" (TLS) connection string —
# NOT the REST URL.
REDIS_URL=rediss://default:PASSWORD@HOST.upstash.io:PORT

# --- Auth secrets — generate with: openssl rand -base64 48 ---
JWT_ACCESS_SECRET=replace-with-32+char-random-string
JWT_REFRESH_SECRET=replace-with-a-different-32+char-random-string
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
PASSWORD_RESET_TTL_MIN=30

# --- Org config ---
SUPPLIER_STATE_CODE=37

# --- CORS: your live frontend origin (no trailing slash) ---
WEB_ORIGIN=https://yourdomain.com

# --- Object storage: Cloudflare R2 (https://dash.cloudflare.com -> R2) ---
# Create a bucket + an API token (R2 > Manage API tokens). Endpoint is your
# account-specific R2 endpoint, NOT a public bucket URL.
S3_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=pixel-academy
S3_ACCESS_KEY=replace-with-r2-access-key-id
S3_SECRET_KEY=replace-with-r2-secret-access-key
S3_FORCE_PATH_STYLE=true

# --- SMTP (optional at first — leave defaults to disable real email sending) ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=Pixel Academy <no-reply@yourdomain.com>
SMTP_SECURE=false

# --- AI / embeddings — keep 'stub' until you wire a real provider ---
EMBEDDING_PROVIDER=stub
EMBEDDING_DIM=1536
LLM_PROVIDER=stub
# ANTHROPIC_API_KEY=

# --- Seed admin — change the password immediately after first login ---
SEED_ADMIN_EMAIL=admin@yourdomain.com
SEED_ADMIN_PASSWORD=ChangeMe-Immediately-2026!
