NODE_ENV=development
PORT=4000

# Postgres (docker compose default)
DATABASE_URL=postgresql://pixel:pixel_dev_pw@localhost:5432/pixel_academy?schema=public
REDIS_URL=redis://localhost:6379

# Auth secrets — generate strong values for production (min 32 chars)
JWT_ACCESS_SECRET=dev_access_secret_change_me_to_32+_chars_long
JWT_REFRESH_SECRET=dev_refresh_secret_change_me_to_32+_chars_long
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
PASSWORD_RESET_TTL_MIN=30

# Pixel Academy's own GST state code (37 = Andhra Pradesh). Drives intra/inter-state GST.
SUPPLIER_STATE_CODE=37

# Frontend origin
WEB_ORIGIN=http://localhost:5173

# Object storage (MinIO docker compose default)
S3_ENDPOINT=http://localhost:9000
S3_REGION=ap-south-1
S3_BUCKET=pixel-academy
S3_ACCESS_KEY=pixel_minio
S3_SECRET_KEY=pixel_minio_dev_pw
S3_FORCE_PATH_STYLE=true

# SMTP (point at Mailpit/Mailhog in dev: docker run -p 1025:1025 -p 8025:8025 axllent/mailpit)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=Pixel Academy <no-reply@pixelacademy.local>
SMTP_SECURE=false

# AI / embeddings — provider abstraction. 'stub' keeps Phase 0 runnable with no keys.
EMBEDDING_PROVIDER=stub
EMBEDDING_DIM=1536
LLM_PROVIDER=stub
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# ANTHROPIC_API_KEY=

# Seed admin (change before any real use)
SEED_ADMIN_EMAIL=admin@pixelacademy.local
SEED_ADMIN_PASSWORD=ChangeMe!2026
